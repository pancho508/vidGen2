{
  "name": "vidgen2",
  "version": "1.0.0",
  "description": "Local AI Video Factory - Convert books into YouTube videos entirely on your machine",
  "type": "module",
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "process": "node dist/cli.js process",
    "schedule": "node dist/cli.js schedule",
    "logs": "node dist/cli.js logs",
    "test:script": "ts-node src/utils/testScriptGeneration.ts",
    "test:voice": "ts-node src/utils/testVoiceGeneration.ts",
    "test:images": "ts-node src/utils/testImageGeneration.ts",
    "test:images-simple": "ts-node src/utils/testImageGenerationSimple.ts",
    "test:images-real": "ts-node src/utils/testRealImageGeneration.ts",
    "generate:image": "ts-node src/utils/generateImageFromScript.ts",
    "test:pipeline": "ts-node src/utils/testFullPipeline.ts",
    "full:run": "npm run build && node dist/utils/fullRun.js",
    "production:run": "npm run build && node dist/utils/productionPipeline.js",
    "clean": "rm -rf dist",
    "start": "npm run build && npm run process"
  },
  "keywords": [
    "ai",
    "video",
    "automation",
    "book-to-video",
    "local-ai",
    "ollama",
    "stable-diffusion"
  ],
  "author": "pancho508",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.5",
    "dotenv": "^16.3.1",
    "epub": "^1.3.0",
    "epub-parser": "^0.1.7",
    "fluent-ffmpeg": "^2.1.2",
    "node-cron": "^3.0.2",
    "pdf-parse": "^1.1.1",
    "pino": "^8.17.2",
    "pino-pretty": "^13.1.3",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
